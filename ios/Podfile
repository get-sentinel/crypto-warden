require_relative '../node_modules/react-native/scripts/react_native_pods'

platform :ios, '15.1'
install! 'cocoapods', :deterministic_uuids => false

ENV['RCT_NEW_ARCH_ENABLED'] = '0'

$RNFirebaseAsStaticFramework = true

target 'CryptoWarden' do
  config = use_native_modules!

  use_frameworks! :linkage => :static
  use_react_native!(
    :path => config[:reactNativePath],
    :hermes_enabled => true,
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  target 'CryptoWardenTests' do
    inherit! :complete
  end

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => true
    )

    # Fix fmt 11.0.2 consteval crash under Xcode 16+/26 Clang (RN 0.78 pins fmt to 11.0.2).
    # fmt's base.h defines FMT_USE_CONSTEVAL unconditionally (no #ifndef guard), so a
    # -DFMT_USE_CONSTEVAL=0 build setting gets overridden. Patch the header directly to
    # force it off, disabling compile-time format-string checks (runtime fallback) and
    # avoiding the broken consteval basic_format_string constructor in format-inl.h.
    fmt_base = "#{installer.sandbox.root}/fmt/include/fmt/base.h"
    if File.exist?(fmt_base)
      content = File.read(fmt_base)
      unless content.include?('#define FMT_USE_CONSTEVAL 0 // patched')
        content = content.gsub(
          "#if FMT_USE_CONSTEVAL\n#  define FMT_CONSTEVAL consteval",
          "#undef FMT_USE_CONSTEVAL\n#define FMT_USE_CONSTEVAL 0 // patched\n#if FMT_USE_CONSTEVAL\n#  define FMT_CONSTEVAL consteval"
        )
        File.write(fmt_base, content)
      end
    end

    # Fix Mac Catalyst deployment target mismatch. FirebaseAuth requires iOS 15.1, which on
    # Mac Catalyst corresponds to MACOSX_DEPLOYMENT_TARGET = 12.1. Without an explicit macOS
    # target, Xcode defaults to macOS 11.1 (= iOS 14.2 on Mac Catalyst), causing the
    # "Compiling for iOS 14.2, but FirebaseAuth minimum is iOS 15.1" error.
    # IPHONEOS_DEPLOYMENT_TARGET governs iOS/sim builds; MACOSX_DEPLOYMENT_TARGET governs
    # Mac Catalyst builds — both need to be set.
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        ios_min = config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'].to_f
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.1' if ios_min < 15.1

        # A per-SDK macosx override (the iOS-equivalent target for Mac Catalyst) trumps the
        # plain IPHONEOS_DEPLOYMENT_TARGET above, so floor it too or Catalyst builds revert to 14.2.
        macabi_min = config.build_settings['IPHONEOS_DEPLOYMENT_TARGET[sdk=macosx*]'].to_f
        config.build_settings['IPHONEOS_DEPLOYMENT_TARGET[sdk=macosx*]'] = '15.1' if macabi_min > 0 && macabi_min < 15.1

        mac_min = config.build_settings['MACOSX_DEPLOYMENT_TARGET'].to_f
        config.build_settings['MACOSX_DEPLOYMENT_TARGET'] = '12.1' if mac_min < 12.1
      end
    end

    # Apply the same MACOSX_DEPLOYMENT_TARGET floor to the main app target (lives in the
    # main xcodeproj, not the Pods project, so the loop above doesn't cover it).
    installer.aggregate_targets.each do |agg|
      agg.user_project.native_targets.each do |target|
        target.build_configurations.each do |config|
          macabi_min = config.build_settings['IPHONEOS_DEPLOYMENT_TARGET[sdk=macosx*]'].to_f
          config.build_settings['IPHONEOS_DEPLOYMENT_TARGET[sdk=macosx*]'] = '15.1' if macabi_min > 0 && macabi_min < 15.1

          mac_min = config.build_settings['MACOSX_DEPLOYMENT_TARGET'].to_f
          config.build_settings['MACOSX_DEPLOYMENT_TARGET'] = '12.1' if mac_min < 12.1
        end
      end
      agg.user_project.save
    end

    # Fix SubscriptionPeriod ambiguity between RevenueCat and StoreKit (RevenueCat < 8.x)
    hybrid_file = "#{installer.sandbox.root}/PurchasesHybridCommon/ios/PurchasesHybridCommon/PurchasesHybridCommon/StoreProduct+HybridAdditions.swift"
    if File.exist?(hybrid_file)
      File.chmod(0644, hybrid_file)
      content = File.read(hybrid_file)
      content = content.gsub(/(?<![A-Za-z.])SubscriptionPeriod/, 'RevenueCat.SubscriptionPeriod')
      File.write(hybrid_file, content)
    end
  end
end
